# --- Database ---
DB_USER=cea_user
DB_PASSWORD=cea_password
DB_HOST=localhost
DB_PORT=3306
DB_NAME=cea_db
# Or set the full URL directly (overrides the DB_* vars above):
# DATABASE_URL=mysql+pymysql://cea_user:cea_password@localhost:3306/cea_db

# --- Auth ---
SECRET_KEY=change-me-in-production
JWT_SECRET_KEY=change-me-jwt-secret

# Institutional email domain(s) allowed to register/login (comma-separated)
INSTITUTIONAL_EMAIL_DOMAIN=student.tce.edu
ADMIN_EMAIL_DOMAINS=student.tce.edu

# --- CORS ---
FRONTEND_ORIGIN=http://localhost:5173

# --- Uploads ---
UPLOAD_FOLDER=./uploads

# --- QR attendance ---
QR_DEFAULT_EXPIRY_MINUTES=10
QR_MAX_EXPIRY_MINUTES=60
QR_WINDOW_BEFORE_MINUTES=15
QR_WINDOW_AFTER_MINUTES=180
QR_SCAN_RATE_LIMIT_ATTEMPTS=5
QR_SCAN_RATE_LIMIT_WINDOW_SECONDS=60
